#!/usr/bin/env node
"use strict";

const { callTool } = require("../lib/mcp");

function usage() {
  console.log(`Usage: pbp-check-nft-status <nft_address> [--json]\n`);
}

(async () => {
  try {
    const args = process.argv.slice(2);
    if (!args.length || args.includes("-h") || args.includes("--help")) {
      usage();
      process.exit(args.length ? 0 : 1);
    }

    const outputJson = args.includes("--json");
    const addr = args.find((a) => !a.startsWith("-"));
    if (!addr) throw new Error("missing nft address");

    let res = await callTool("get_nft", { mintAddress: addr });
    let count = Number(res?.structuredContent?.count || 0);
    if (!count) {
      res = await callTool("get_nft", { tokenAddress: addr });
      count = Number(res?.structuredContent?.count || 0);
    }
    if (!count) throw new Error(`No NFT found for: ${addr}`);

    const nft = (res?.structuredContent?.nfts || [])[0];
    if (!nft) throw new Error(`No NFT found for: ${addr}`);

    if (outputJson) {
      console.log(JSON.stringify(nft, null, 2));
      return;
    }

    console.log(`Name: ${nft.name || "unknown"}`);
    console.log(`NFT Account: ${nft.nftAccount || "unknown"}`);
    console.log(`Collection: ${nft.collection || "unknown"}`);
    console.log(`Symbol: ${nft.symbol || "unknown"}`);
    console.log(`On Cooldown: ${String(Boolean(nft.onCooldown))}`);
    console.log(`Cooldown Ends At: ${nft.cooldownEndsAt || "-"}`);
    console.log(`Level: ${nft.level ?? 0}`);
    console.log(`XP: ${nft.currentExp ?? 0} / ${nft.totalExp ?? 0}`);
  } catch (e) {
    console.error(`error: ${e.message}`);
    process.exit(2);
  }
})();
