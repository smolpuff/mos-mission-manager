#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PBP_MCP="${PROJECT_ROOT}/bin/pbp-mcp"

OUTPUT_JSON=0
NFT_ADDR=""

usage() {
  cat <<USAGE
Usage: $(basename "$0") <nft_address> [--json]

Checks one NFT status via pbp-mcp get_nft and prints cooldown fields.

Options:
  --json       Print the matched NFT object as JSON
  -h, --help   Show this help
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      OUTPUT_JSON=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$NFT_ADDR" ]]; then
        echo "Only one nft_address is allowed." >&2
        usage >&2
        exit 1
      fi
      NFT_ADDR="$1"
      shift
      ;;
  esac
done

if [[ -z "$NFT_ADDR" ]]; then
  usage >&2
  exit 1
fi

# Try mintAddress first; if no match, fallback to tokenAddress.
ARGS_JSON="$(jq -cn --arg addr "$NFT_ADDR" '{mintAddress: $addr}')"
RESP="$("$PBP_MCP" call get_nft --args "$ARGS_JSON")"

MATCHED_COUNT="$(echo "$RESP" | jq -r '.structuredContent.count // 0')"
if [[ "$MATCHED_COUNT" == "0" ]]; then
  ARGS_JSON="$(jq -cn --arg addr "$NFT_ADDR" '{tokenAddress: $addr}')"
  RESP="$("$PBP_MCP" call get_nft --args "$ARGS_JSON")"
fi

SUCCESS="$(echo "$RESP" | jq -r '.structuredContent.success // false')"
if [[ "$SUCCESS" != "true" ]]; then
  echo "$RESP" | jq -r '.content[0].text // "get_nft failed"'
  exit 2
fi

NFT_JSON="$(echo "$RESP" | jq -c '.structuredContent.nfts[0] // empty')"
if [[ -z "$NFT_JSON" ]]; then
  echo "No NFT found for: $NFT_ADDR" >&2
  exit 3
fi

if [[ "$OUTPUT_JSON" -eq 1 ]]; then
  echo "$NFT_JSON" | jq '.'
  exit 0
fi

echo "$NFT_JSON" | jq -r '
  "Name: " + (.name // "unknown"),
  "NFT Account: " + (.nftAccount // "unknown"),
  "Collection: " + (.collection // "unknown"),
  "Symbol: " + (.symbol // "unknown"),
  "On Cooldown: " + ((.onCooldown // false) | tostring),
  "Cooldown Ends At: " + (.cooldownEndsAt // "-"),
  "Level: " + ((.level // 0) | tostring),
  "XP: " + ((.currentExp // 0) | tostring) + " / " + ((.totalExp // 0) | tostring)
'
