#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PBP_MCP="${PROJECT_ROOT}/bin/pbp-mcp"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: $(basename "$0") <nftId>"
  echo
  echo "Example:"
  echo "  ./bin/pbp-reset-walkthrough 3Lg...rbMV"
  exit 0
fi

if [[ $# -lt 1 ]]; then
  echo "Usage: $(basename "$0") <nftId>"
  echo
  echo "Example:"
  echo "  ./bin/pbp-reset-walkthrough 3Lg...rbMV"
  exit 1
fi

NFT_ID="$1"

echo "1) Preparing reset transaction for nftId=${NFT_ID}"
PREP="$("$PBP_MCP" call prepare_nft_cooldown_reset --args "$(jq -cn --arg nftId "$NFT_ID" '{nftId:$nftId}')" )"
echo "$PREP" | jq .

echo
echo "2) Detecting key fields from prepare response..."

SC="$(echo "$PREP" | jq -c '.structuredContent // {}')"
TOKEN_KEY="$(echo "$SC" | jq -r '
  (to_entries | map(select(.key|test("token";"i")))[0].key) // empty
')"
TX_KEY="$(echo "$SC" | jq -r '
  (to_entries | map(select(.key|test("tx|transaction";"i")))[0].key) // empty
')"

if [[ -z "$TX_KEY" ]]; then
  echo "Could not auto-detect transaction field. Inspect .structuredContent in output above."
else
  echo "Transaction field: $TX_KEY"
  echo "Unsigned tx preview (first 80 chars):"
  echo "$SC" | jq -r --arg k "$TX_KEY" '.[$k] | tostring | .[0:80]'
fi

if [[ -z "$TOKEN_KEY" ]]; then
  echo "No token-like field auto-detected."
else
  echo "Token field: $TOKEN_KEY"
  echo "Token value:"
  echo "$SC" | jq -r --arg k "$TOKEN_KEY" '.[$k]'
fi

echo
echo "3) Sign the unsigned tx with your wallet (same wallet linked to PbP)."
echo "   - Input to signer: the unsigned tx field shown above (usually base64)."
echo "   - Output needed: signed tx (usually base64)."

echo
echo "4) Submit signed reset."
echo "Fill in <SIGNED_TX_BASE64> in this template:"
echo

if [[ -n "$TOKEN_KEY" && -n "$TX_KEY" ]]; then
  TOKEN_VAL="$(echo "$SC" | jq -r --arg k "$TOKEN_KEY" '.[$k]')"
  jq -cn \
    --arg tokenKey "$TOKEN_KEY" \
    --arg tokenVal "$TOKEN_VAL" \
    '{
      tool: "submit_signed_nft_cooldown_reset",
      args: {
        ($tokenKey): $tokenVal,
        signedTx: "<SIGNED_TX_BASE64>"
      }
    }'
else
  jq -cn '{
    tool: "submit_signed_nft_cooldown_reset",
    args: {
      "<token_field_from_prepare>": "<token_value_from_prepare>",
      signedTx: "<SIGNED_TX_BASE64>"
    }
  }'
fi

echo
echo "Run submit:"
echo "  ./bin/pbp-mcp call submit_signed_nft_cooldown_reset --args '<JSON_ARGS>'"
