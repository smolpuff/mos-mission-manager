#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PBP_MCP="${PROJECT_ROOT}/bin/pbp-mcp"

call_tool() {
  local tool_name="$1"
  local args_json="$2"
  local resp
  local err_file
  err_file="$(mktemp)"

  if ! resp="$("$PBP_MCP" call "$tool_name" --args "$args_json" 2>"$err_file")"; then
    jq -nc --arg err "$(cat "$err_file")" '{"data": null, "error": $err}'
    rm -f "$err_file"
    return 0
  fi
  rm -f "$err_file"

  if ! echo "$resp" | jq -e . >/dev/null 2>&1; then
    jq -nc --arg err "Invalid JSON response from $tool_name" '{"data": null, "error": $err}'
    return 0
  fi

  echo "$resp" | jq -c '
    if (.isError // false) == true then
      {"data": null, "error": (.content[0].text // "tool call failed")}
    else
      {"data": (.structuredContent // null), "error": null}
    end
  '
}

AUTH="$(call_tool who_am_i '{}')"
MISSIONS="$(call_tool get_user_missions '{}')"
WALLET="$(call_tool get_wallet_summary '{}')"
ORDERS="$(call_tool get_user_orders '{"page":1}')"
CATALOG="$(call_tool get_mission_catalog '{}')"
SHOP="$(call_tool get_shop_catalog '{}')"

NOW_ISO="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

jq -nc \
  --arg now "$NOW_ISO" \
  --argjson auth "$AUTH" \
  --argjson missions "$MISSIONS" \
  --argjson wallet "$WALLET" \
  --argjson orders "$ORDERS" \
  --argjson catalog "$CATALOG" \
  --argjson shop "$SHOP" \
  '
  def mission_array($m):
    ($m.data.missions.missions //
     (if ($m.data.missions|type) == "array" then $m.data.missions else empty end) //
     (if ($m.data|type) == "array" then $m.data else empty end) //
     []);

  def to_num_or_zero:
    (tonumber? // 0);

  def mission_progress_num($m):
    ($m.progress // $m.currentProgress // 0 | to_num_or_zero);

  def mission_goal_num($m):
    ($m.goal // $m.task_amount // $m.target // 0 | to_num_or_zero);

  def is_claimable($m):
    (($m.claimable // $m.isClaimable // false) == true);

  def is_near_complete($m):
    (mission_goal_num($m) > 0 and mission_progress_num($m) < mission_goal_num($m) and mission_progress_num($m) >= (mission_goal_num($m) - 1));

  def is_cooldown_blocked($m):
    (($m.onCooldown // false) == true)
    or (($m.cooldownSeconds // $m.cooldown // $m.cooldown_minutes // 0 | to_num_or_zero) > 0);

  ($auth.error == null) as $auth_ok |
  (mission_array($missions)) as $mission_list |
  [
    (if $auth.error != null then "auth: " + $auth.error else empty end),
    (if $missions.error != null then "missions: " + $missions.error else empty end),
    (if $wallet.error != null then "wallet: " + $wallet.error else empty end),
    (if $orders.error != null then "orders: " + $orders.error else empty end),
    (if $catalog.error != null then "catalog: " + $catalog.error else empty end),
    (if $shop.error != null then "shop: " + $shop.error else empty end)
  ] as $notes |
  {
    ok: ($notes | length == 0),
    generated_at: $now,
    auth: {
      connected: $auth_ok,
      user: $auth.data,
      error: $auth.error
    },
    missions: $missions,
    wallet: $wallet,
    orders: $orders,
    catalog: $catalog,
    shop: $shop,
    summary: {
      claimable_count: ($mission_list | map(select(is_claimable(.))) | length),
      near_complete_count: ($mission_list | map(select(is_near_complete(.))) | length),
      cooldown_blocked_count: ($mission_list | map(select(is_cooldown_blocked(.))) | length),
      notes: $notes
    }
  }'
