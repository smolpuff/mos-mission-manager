#!/usr/bin/env node
"use strict";

const { callTool } = require("../lib/mcp");
const { normalizeNftsResponse } = require("../lib/pbp");

function usage() {
  console.log(`Usage: pbp-live-reset-candidates [options]

Options:
  --interval <sec> (default 60)
  --top <n> (default 5)
  --collection <name>
  --assigned-mission-id <id>
  --once
  --no-clear
  -h, --help`);
}

function parse(argv) {
  const out = { interval: 60, top: 5, collection: "", assignedMissionId: "", once: false, noClear: false };
  for (let i = 0; i < argv.length; i += 1) {
    const a = argv[i];
    if (a === "-h" || a === "--help") return { help: true };
    if (a === "--interval") out.interval = Number(argv[++i]);
    else if (a === "--top") out.top = Number(argv[++i]);
    else if (a === "--collection") out.collection = argv[++i] || "";
    else if (a === "--assigned-mission-id") out.assignedMissionId = argv[++i] || "";
    else if (a === "--once") out.once = true;
    else if (a === "--no-clear") out.noClear = true;
    else throw new Error(`Unknown argument: ${a}`);
  }
  return out;
}

async function cycle(cfg) {
  if (!cfg.noClear) process.stdout.write("\x1b[H\x1b[2J");
  console.log(new Date().toString());

  let nfts = [];
  try {
    const args = cfg.assignedMissionId ? { assignedMissionId: cfg.assignedMissionId } : {};
    const res = await callTool("get_mission_nfts", args);
    nfts = normalizeNftsResponse(res);
  } catch (e) {
    console.log(`Failed to fetch NFTs: ${e.message}`);
    return;
  }

  let rows = nfts
    .map((n) => ({
      nftId: n.id || n.nftId || n.nftAccount || n.mintAddress || n.tokenAddress || n.mint || "",
      name: n.name || n.nftName || n.displayName || "unknown",
      collection: n.collection || n.collectionName || n.collectionKey || "",
      cooldown: Number(n.cooldownSeconds ?? n.cooldown ?? 0) || 0,
    }))
    .filter((r) => r.nftId && r.cooldown > 0);

  if (cfg.collection) rows = rows.filter((r) => r.collection === cfg.collection);

  const quotes = [];
  for (const row of rows) {
    let cost = null;
    try {
      const q = await callTool("prepare_nft_cooldown_reset", { nftId: row.nftId });
      const sc = q?.structuredContent || {};
      cost = Number(
        sc.costPbp ?? sc.resetCostPbp ?? sc.resetCost ?? sc.requiredPbp ?? sc.price ?? sc.fee ?? sc?.quote?.totalPbp,
      );
      if (!Number.isFinite(cost)) cost = null;
    } catch {
      cost = null;
    }
    quotes.push({ ...row, cost });
  }

  quotes.sort((a, b) => (a.cost ?? 1e9) - (b.cost ?? 1e9) || a.cooldown - b.cooldown);

  console.log(`Cooldown NFTs matched: ${quotes.length}`);
  if (cfg.collection) console.log(`Collection filter: ${cfg.collection}`);
  if (cfg.assignedMissionId) console.log(`Mission filter: ${cfg.assignedMissionId}`);
  console.log("");

  if (!quotes.length) {
    console.log("No cooldown NFTs match current filters.");
    return;
  }

  console.log("Cheapest reset candidates:");
  quotes.slice(0, cfg.top).forEach((q, i) => {
    console.log(`${i + 1}. cost=${q.cost ?? "N/A"} cooldown=${q.cooldown}s nft=${q.nftId} name=${q.name} collection=${q.collection}`);
  });
}

(async () => {
  try {
    const cfg = parse(process.argv.slice(2));
    if (cfg.help) {
      usage();
      return;
    }
    do {
      await cycle(cfg);
      if (cfg.once) break;
      await new Promise((r) => setTimeout(r, cfg.interval * 1000));
    } while (true);
  } catch (e) {
    console.error(`error: ${e.message}`);
    usage();
    process.exit(2);
  }
})();
