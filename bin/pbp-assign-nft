#!/usr/bin/env node
"use strict";

const { callTool } = require("../lib/mcp");
const { getUserMissions, getMissionNfts, assignedMissionId, pickAssignableNft } = require("../lib/pbp");

function usage() {
  console.log("Usage: pbp-assign-nft <mission_slot_number>");
}

(async () => {
  try {
    const arg = process.argv[2];
    if (!arg || arg === "-h" || arg === "--help") {
      usage();
      process.exit(arg ? 0 : 1);
    }

    const slot = Number(arg);
    if (!Number.isInteger(slot) || slot < 1) throw new Error("slot must be integer >= 1");

    const missions = await getUserMissions();
    const mission = missions[slot - 1];
    if (!mission) throw new Error(`No mission found in slot ${slot}`);

    const missionName = mission.name || mission.title || "(unnamed)";
    const id = assignedMissionId(mission);
    if (!id) throw new Error(`Mission in slot ${slot} does not have an assigned mission id`);

    const nfts = await getMissionNfts({ assignedMissionId: id });
    const nft = pickAssignableNft(nfts);
    if (!nft) throw new Error(`No assignable NFT found for mission '${missionName}' (slot ${slot})`);

    console.log(`Assigning NFT ${nft} to mission '${missionName}' (slot ${slot})`);
    const res = await callTool("assign_nft_to_mission", {
      assignedMissionId: id,
      nftAccount: nft,
    });
    console.log(JSON.stringify(res, null, 2));
  } catch (e) {
    console.error(`error: ${e.message}`);
    process.exit(2);
  }
})();
