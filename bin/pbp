#!/usr/bin/env node
"use strict";

const { getUserMissions } = require("../lib/pbp");

function usage() {
  console.log(`Usage: pbp [--json] <command>\n\nCommands:\n  status\n  suggest`);
}

(async () => {
  try {
    const args = process.argv.slice(2);
    const asJson = args.includes("--json");
    const cmd = args.find((a) => !a.startsWith("-"));
    if (!cmd || cmd === "-h" || cmd === "--help") {
      usage();
      process.exit(cmd ? 0 : 1);
    }

    if (cmd === "status") {
      const missions = await getUserMissions();
      const claimable = missions.filter((m) => (m.claimable ?? m.isClaimable) === true);
      const payload = {
        claimable_count: claimable.length,
        missions: missions.map((m) => ({
          id: m.id || m.assigned_mission_id || m.assignedMissionId,
          name: m.name,
          progress: m.progress ?? m.currentProgress ?? "0",
          claimable: (m.claimable ?? m.isClaimable) === true,
          cooldown_minutes: m.cooldown_minutes ?? null,
          reward_value: m.reward_value ?? m.rewardValue ?? m.prize_amount ?? 0,
        })),
      };
      if (asJson) console.log(JSON.stringify(payload, null, 2));
      else {
        console.log(`- Claimable Missions: ${payload.claimable_count}`);
        for (const m of payload.missions) {
          const cd = m.cooldown_minutes == null ? "-" : `${m.cooldown_minutes}m`;
          console.log(`- ${m.name}: ${m.progress} | claimable=${m.claimable} | cooldown=${cd} | reward=${m.reward_value}`);
        }
      }
      return;
    }

    if (cmd === "suggest") {
      const missions = await getUserMissions();
      const suggestions = missions
        .filter((m) => (m.claimable ?? m.isClaimable) === true)
        .map((m) => ({ action: `Claim: ${m.name}`, priority: 100 }));
      const payload = { suggestions };
      console.log(JSON.stringify(payload, null, 2));
      return;
    }

    throw new Error(`Unknown command: ${cmd}`);
  } catch (e) {
    console.error(`error: ${e.message}`);
    process.exit(2);
  }
})();
