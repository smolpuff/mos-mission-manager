#!/usr/bin/env node
"use strict";

const { callTool } = require("../lib/mcp");
const { normalizeNftsResponse } = require("../lib/pbp");

function usage() {
  console.log(`Usage: pbp-get-mission-nfts [options]

Options:
  --assigned-mission-id <id>
  --cooldown-filter <value>
  --limit <n>
  --offset <n>
  -h, --help`);
}

function parse(argv) {
  const out = {};
  for (let i = 0; i < argv.length; i += 1) {
    const a = argv[i];
    if (a === "-h" || a === "--help") return { help: true };
    if (a === "--assigned-mission-id") out.assignedMissionId = argv[++i];
    else if (a === "--cooldown-filter") out.cooldownFilter = argv[++i];
    else if (a === "--limit") out.limit = Number(argv[++i]);
    else if (a === "--offset") out.offset = Number(argv[++i]);
    else throw new Error(`Unknown argument: ${a}`);
  }
  return out;
}

(async () => {
  try {
    const parsed = parse(process.argv.slice(2));
    if (parsed.help) {
      usage();
      return;
    }
    const res = await callTool("get_mission_nfts", parsed);
    console.log(JSON.stringify(normalizeNftsResponse(res), null, 2));
  } catch (e) {
    console.error(`error: ${e.message}`);
    usage();
    process.exit(2);
  }
})();
