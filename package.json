{
  "name": "missions-v3-mcp",
  "version": "3.1.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "nodemon app.js",
    "dev:debug": "nodemon app.js --debug",
    "start": "node app.js",
    "start:debug": "node app.js --debug",
    "desktop": "electron .",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron . 2>&1",
    "desktop:build": "vite build",
    "desktop:dist": "npm run desktop:build && electron-builder",
    "desktop:dist:mac": "npm run desktop:build && electron-builder --mac dir zip",
    "desktop:dist:win": "npm run desktop:build && electron-builder --win portable",
    "desktop:dist:linux": "npm run desktop:build && electron-builder --linux AppImage",
    "build": "npm run build:mac && npm run build:win && npm run zip:builds",
    "bundle": "mkdir -p binaries && npx esbuild app.js --bundle --platform=node --format=cjs --target=node22 --outfile=binaries/app.bundle.cjs",
    "build:mac": "npm run bundle && npm run build:mac:arm64 && npm run build:mac:x64",
    "build:mac:arm64": "node scripts/build-sea.js mac arm64 && node scripts/build-mac-app.js arm64",
    "build:mac:x64": "node scripts/build-sea.js mac x64 && node scripts/build-mac-app.js x64",
    "build:mac:verify": "codesign -dv binaries/missions-mcp-macos-arm64-$npm_package_version.app",
    "build:win": "npm run bundle && node scripts/build-sea.js win x64",
    "zip:builds": "node scripts/zip-builds.js"
  },
  "build": {
    "appId": "dephlect.pbp-missions.desktop",
    "productName": "missions-v3-mcp",
    "icon": "icon",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "directories": {
      "output": "release",
      "buildResources": "electron/icons"
    },
    "files": [
      "app.js",
      "electron/**/*",
      "src/**/*",
      "lib/**/*",
      "bin/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dir",
        "zip"
      ]
    },
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.0",
    "postject": "^1.0.0-alpha.6",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@solana/kit": "^6.7.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "bip39": "^3.1.0",
    "daisyui": "^5.5.19",
    "ed25519-hd-key": "^1.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8"
  }
}
